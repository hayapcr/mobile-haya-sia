<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="Learning Dashboard"
        android:textColor="@color/black"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pilih materi untuk memulai"
        android:textColor="#000000"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToSecond"
        android:layout_width="280dp"
        android:layout_height="60dp"
        android:text="Pertemuan 2"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:backgroundTint="#6200EE"
        app:cornerRadius="16dp"
        app:elevation="8dp"
        app:icon="@android:drawable/ic_menu_today"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.25" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToThird"
        android:layout_width="280dp"
        android:layout_height="60dp"
        android:text="Pertemuan 3"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:backgroundTint="#3700B3"
        app:cornerRadius="16dp"
        app:elevation="8dp"
        app:icon="@android:drawable/ic_menu_today"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.36" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToFourth"
        android:layout_width="280dp"
        android:layout_height="60dp"
        android:text="Pertemuan 4"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:backgroundTint="#03DAC5"
        android:textColor="#000000"
        app:iconTint="#000000"
        app:cornerRadius="16dp"
        app:elevation="8dp"
        app:icon="@android:drawable/ic_menu_today"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.47" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToFifth"
        android:layout_width="280dp"
        android:layout_height="60dp"
        android:text="Pertemuan 5"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:backgroundTint="#018786"
        app:cornerRadius="16dp"
        app:elevation="8dp"
        app:icon="@android:drawable/ic_menu_today"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.58" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToSeven"
        android:layout_width="280dp"
        android:layout_height="60dp"
        android:text="Pertemuan 7"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:backgroundTint="#BB86FC"
        android:textColor="#000000"
        app:iconTint="#000000"
        app:cornerRadius="16dp"
        app:elevation="8dp"
        app:icon="@android:drawable/ic_menu_today"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.69" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:text="Logout"
        android:textColor="#CF6679"
        app:strokeColor="#CF6679"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>